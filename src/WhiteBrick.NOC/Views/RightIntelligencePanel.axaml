<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:widgets="clr-namespace:WhiteBrick.NOC.Widgets"
             x:Class="WhiteBrick.NOC.Views.RightIntelligencePanel">

  <Border CornerRadius="20"
          Background="#D00A1020"
          BorderBrush="#1F6A8D"
          BorderThickness="1"
          Padding="14"
          MaxWidth="360">

    <Grid RowDefinitions="Auto,150,130,140,*,145,145"
          RowSpacing="12">

      <TextBlock Text="LIVE INTELLIGENCE"
                 FontSize="20"
                 FontWeight="Bold"
                 Foreground="#C8F6FF"/>

      <Grid Grid.Row="1"
            ColumnDefinitions="*,*"
            Margin="0,8,0,0"
            ColumnSpacing="10">
        <widgets:SystemMicroPanelControl Cpu="{Binding Cpu}"
                                         Memory="{Binding Memory}"
                                         Packets="{Binding PacketRate}"
                                         Mode="{Binding OperatingMode}"/>

        <Grid Grid.Column="1"
              ColumnDefinitions="*,*"
              ColumnSpacing="8">
          <widgets:GaugeRingControl Value="{Binding Cpu}" Label="CPU"/>
          <widgets:GaugeRingControl Grid.Column="1" Value="{Binding Memory}" Label="MEM"/>
        </Grid>
      </Grid>

      <Border Grid.Row="2"
              CornerRadius="10"
              Background="#0A081018"
              BorderBrush="#245B7D"
              BorderThickness="1"
              Padding="10">
        <StackPanel>
          <TextBlock Text="WEATHER"
                     Foreground="#BDEEFF"
                     FontSize="12"
                     FontWeight="Bold"/>

          <Grid Margin="0,8,0,0"
                ColumnDefinitions="*,Auto">
            <StackPanel>
              <TextBlock Text="Ashland, VA"
                         Foreground="#EAFBFF"
                         FontWeight="Bold"/>
              <TextBlock Text="{Binding WeatherCondition}"
                         Foreground="#BDEEFF"
                         FontSize="12"/>
              <TextBlock Text="{Binding WeatherTemperature}"
                         Foreground="#8EF8FF"
                         FontSize="20"
                         FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Right">
              <TextBlock Text="{Binding WeatherWind}"
                         Foreground="#BDEEFF"
                         FontSize="12"/>
              <TextBlock Text="Provider staged"
                         Foreground="#8899AA"
                         FontSize="11"/>
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <Border Grid.Row="3"
              CornerRadius="10"
              Background="#0A081018"
              BorderBrush="#24D7FF"
              BorderThickness="1"
              Padding="10">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Text="NETWORK RADAR"
                     Foreground="#BDEEFF"
                     FontSize="12"
                     FontWeight="Bold"/>

          <Grid Grid.Row="1"
                Margin="0,6,0,0">
            <widgets:RadarControl HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"/>

            <Canvas IsHitTestVisible="False">
              <Ellipse Width="6" Height="6" Fill="#8EF8FF" Canvas.Left="48" Canvas.Top="24" Opacity="0.9"/>
              <Ellipse Width="6" Height="6" Fill="#6EFFA1" Canvas.Left="88" Canvas.Top="44" Opacity="0.9"/>
              <Ellipse Width="6" Height="6" Fill="#FFD28A" Canvas.Left="124" Canvas.Top="36" Opacity="0.9"/>
            </Canvas>
          </Grid>
        </Grid>
      </Border>

      <Border Grid.Row="4"
              CornerRadius="10"
              Background="#0A081018"
              BorderBrush="#2C3A55"
              BorderThickness="1"
              Padding="10"
              ClipToBounds="True">
        <Grid RowDefinitions="Auto,*">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="LIVE CONSOLE"
                       Foreground="#BDEEFF"
                       FontSize="15"
                       FontWeight="Bold"/>
            <TextBlock Grid.Column="1"
                       Text="EVENT STREAM"
                       Foreground="#6EFFA1"
                       FontSize="10"
                       VerticalAlignment="Center"/>
          </Grid>

          <ScrollViewer Grid.Row="1"
                        Margin="0,8,0,0"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding ConsoleLines}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}"
                             Foreground="#BDEEFF"
                             FontSize="12"
                             FontFamily="Consolas"
                             TextWrapping="NoWrap"
                             Margin="0,0,0,5"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>

      <Border Grid.Row="5"
              CornerRadius="10"
              Background="#0A081018"
              BorderBrush="#5B4CFF"
              BorderThickness="1"
              Padding="10">
        <StackPanel>
          <TextBlock Text="CAMERAS"
                     Foreground="#BDEEFF"
                     FontSize="12"
                     FontWeight="Bold"/>

          <StackPanel Margin="0,8,0,0" Spacing="6">
            <Grid ColumnDefinitions="18,*,Auto">
              <Ellipse Width="10" Height="10" Fill="#6EFFA1"/>
              <TextBlock Grid.Column="1" Text="Ring Front" Foreground="#BDEEFF" Margin="8,0"/>
              <TextBlock Grid.Column="2" Text="LIVE" Foreground="#6EFFA1"/>
            </Grid>

            <Grid ColumnDefinitions="18,*,Auto">
              <Ellipse Width="10" Height="10" Fill="#6EFFA1"/>
              <TextBlock Grid.Column="1" Text="Driveway" Foreground="#BDEEFF" Margin="8,0"/>
              <TextBlock Grid.Column="2" Text="LIVE" Foreground="#6EFFA1"/>
            </Grid>

            <Grid ColumnDefinitions="18,*,Auto">
              <Ellipse Width="10" Height="10" Fill="#FFD28A"/>
              <TextBlock Grid.Column="1" Text="Office" Foreground="#BDEEFF" Margin="8,0"/>
              <TextBlock Grid.Column="2" Text="RECORDING" Foreground="#FFD28A"/>
            </Grid>

            <Grid ColumnDefinitions="18,*,Auto">
              <Ellipse Width="10" Height="10" Fill="#8899AA"/>
              <TextBlock Grid.Column="1" Text="Garage" Foreground="#BDEEFF" Margin="8,0"/>
              <TextBlock Grid.Column="2" Text="OFFLINE" Foreground="#8899AA"/>
            </Grid>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Grid.Row="6"
              CornerRadius="10"
              Background="#0A081018"
              BorderBrush="#1F6A8D"
              BorderThickness="1"
              Padding="10">
        <StackPanel>
          <TextBlock Text="PACKET INSPECTOR"
                     Foreground="#BDEEFF"
                     FontSize="14"
                     FontWeight="Bold"/>

          <Grid Margin="0,8,0,0"
                RowDefinitions="Auto,Auto,Auto"
                ColumnDefinitions="*,*,Auto"
                RowSpacing="5">
            <TextBlock Text="TYPE" Foreground="#89D7FF" FontSize="11"/>
            <TextBlock Grid.Column="1" Text="ROUTE" Foreground="#89D7FF" FontSize="11"/>
            <TextBlock Grid.Column="2" Text="STATUS" Foreground="#89D7FF" FontSize="11"/>

            <TextBlock Grid.Row="1" Text="ICMP" Foreground="#BDEEFF" FontSize="12"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="WAN → CORE" Foreground="#BDEEFF" FontSize="12"/>
            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding Latency}" Foreground="#6EFFA1" FontSize="12"/>

            <TextBlock Grid.Row="2" Text="TCP" Foreground="#BDEEFF" FontSize="12"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="LAN → NOC" Foreground="#BDEEFF" FontSize="12"/>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding PacketRate}" Foreground="#8EF8FF" FontSize="12"/>
          </Grid>
        </StackPanel>
      </Border>

    </Grid>
  </Border>
</UserControl>
