<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:widgets="clr-namespace:WhiteBrick.NOC.Widgets"
        xmlns:views="clr-namespace:WhiteBrick.NOC.Views"
        x:Class="WhiteBrick.NOC.Views.MainWindow"
        Width="1600"
        Height="900"
        MinWidth="1200"
        MinHeight="720"
        Title="{Binding Title}"
        Background="#050811">

  <Grid RowDefinitions="88,*,64"
        ColumnDefinitions="360,*,360"
        Margin="20"
        RowSpacing="18"
        ColumnSpacing="18">

    <widgets:ParticleFieldControl Grid.RowSpan="3" Grid.ColumnSpan="3"/>
    <widgets:AmbientMoodOverlayControl Grid.RowSpan="3" Grid.ColumnSpan="3"
                                       Mode="{Binding OperatingMode}"/>

    <Border Grid.Row="0"
            Grid.ColumnSpan="3"
            CornerRadius="18"
            Background="#D0101827"
            BorderBrush="#245B7D"
            BorderThickness="1"
            Padding="12,8">
      <Grid ColumnDefinitions="320,*,260">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <Border Width="44" Height="44" CornerRadius="8"
                  Background="#06202A"
                  BorderBrush="#2E9AB8"
                  BorderThickness="1">
            <TextBlock Text="WB"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#BFEFFF"
                       FontWeight="Bold"/>
          </Border>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="WHITE BRICK NOC OS"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#D9F7FF"/>
            <TextBlock Text="Network Operations Center"
                       FontSize="12"
                       Foreground="#88CFE8"/>
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
          <TextBlock Text="WHITE BRICK NOC OS"
                     FontSize="22"
                     FontWeight="Bold"
                     Foreground="#EAFBFF"/>
          <TextBlock Text="Network Operations Center"
                     FontSize="13"
                     Foreground="#9EE6FF"
                     HorizontalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Spacing="18">
          <StackPanel>
            <TextBlock Text="{Binding Time}"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#8EF8FF"
                       HorizontalAlignment="Right"/>
            <TextBlock Text="DATE"
                       FontSize="11"
                       Foreground="#8899AA"
                       HorizontalAlignment="Right"/>
          </StackPanel>
          <StackPanel>
            <TextBlock Text="UPTIME"
                       FontSize="12"
                       Foreground="#BDEEFF"
                       HorizontalAlignment="Right"/>
            <TextBlock Text="17d 04h"
                       FontSize="11"
                       Foreground="#88CFE8"
                       HorizontalAlignment="Right"/>
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>

    <views:LeftOperationsPanel Grid.Row="1" Grid.Column="0"/>
    <views:CenterMissionPanel Grid.Row="1" Grid.Column="1"/>
    <views:RightIntelligencePanel Grid.Row="1" Grid.Column="2"/>

    <Border Grid.Row="2"
            Grid.ColumnSpan="3"
            CornerRadius="14"
            Background="#0E0913"
            BorderBrush="#123642"
            BorderThickness="1"
            Padding="12,10">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <TextBlock Text="{Binding OperatingMode}"
                   Foreground="#8EF8FF"
                   FontSize="13"
                   FontWeight="Bold"/>
        <TextBlock Grid.Column="1"
                   Text="{Binding AlertBannerText}"
                   Foreground="#D9F7FF"
                   FontSize="13"
                   HorizontalAlignment="Center"/>
        <TextBlock Grid.Column="2"
                   Text="{Binding Time}"
                   Foreground="#BDEEFF"
                   FontSize="13"/>
      </Grid>
    </Border>

  </Grid>
</Window>