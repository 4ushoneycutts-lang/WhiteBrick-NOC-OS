<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:widgets="clr-namespace:WhiteBrick.NOC.Widgets"
        x:Class="WhiteBrick.NOC.Views.MainWindow"
        Width="1600"
        Height="900"
        MinWidth="1200"
        MinHeight="720"
        Title="{Binding Title}"
        Background="#050811">
  <Window.Styles>
    <Style Selector="ListBox#NavList ListBoxItem:selected">
      <Setter Property="Background" Value="#163346" />
      <Setter Property="Foreground" Value="#D9F7FF" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style Selector="ListBox#NavList ListBoxItem:pointerover">
      <Setter Property="Background" Value="#0F2A36" />
      <Setter Property="Foreground" Value="#BFEFFF" />
    </Style>
    <Style Selector="ListBox#NavList">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="4" />
    </Style>
  </Window.Styles>

  <Grid>
    <widgets:ParticleFieldControl/>
    <widgets:AmbientMoodOverlayControl Mode="{Binding OperatingMode}"/>

    <Grid RowDefinitions="72,*,56" ColumnDefinitions="220,1.08*,1.72*,1.08*" Margin="18">
      <Border Grid.Row="0" Grid.ColumnSpan="4" CornerRadius="18" Background="#D0101827" BorderBrush="#245B7D" BorderThickness="1" Padding="12,8">
        <Grid RowDefinitions="*,8" ColumnDefinitions="160,*,260" VerticalAlignment="Center">
          <!-- Logo / Brand area -->
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Border Width="44" Height="44" CornerRadius="8" Background="#06202A" BorderBrush="#2E9AB8" BorderThickness="1">
              <TextBlock Text="WB" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#BFEFFF" FontWeight="Bold"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="WHITE BRICK NOC OS" FontSize="16" FontWeight="Bold" Foreground="#D9F7FF"/>
              <TextBlock Text="Network Operations Center" FontSize="11" Foreground="#88CFE8"/>
            </StackPanel>
          </StackPanel>

          <!-- Center application title area (keeps header balanced) -->
          <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="WHITE BRICK NOC OS" FontSize="20" FontWeight="Bold" Foreground="#EAFBFF"/>
            <TextBlock Text="Network Operations Center" FontSize="12" Foreground="#9EE6FF"/>
          </StackPanel>

          <!-- Right side: clock / date / uptime placeholders -->
          <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="18">
            <StackPanel>
              <TextBlock Text="{Binding Time}" FontSize="18" FontWeight="Bold" Foreground="#8EF8FF" HorizontalAlignment="Right"/>
              <TextBlock Text="DATE" FontSize="11" Foreground="#8899AA" HorizontalAlignment="Right"/>
            </StackPanel>
            <StackPanel>
              <TextBlock Text="UPTIME" FontSize="12" Foreground="#BDEEFF" HorizontalAlignment="Right"/>
              <TextBlock Text="17d 04h" FontSize="11" Foreground="#88CFE8" HorizontalAlignment="Right"/>
            </StackPanel>
          </StackPanel>

          <!-- Thin heartbeat / status line -->
          <Grid Grid.Row="1" Grid.ColumnSpan="3" Height="8" Margin="6,4,6,0">
            <Rectangle Height="2" Fill="#07202B" VerticalAlignment="Top" Margin="0,3,0,0" RadiusX="1" RadiusY="1" Opacity="0.6"/>
            <Rectangle Height="1" Fill="#1B4B5E" VerticalAlignment="Top" Margin="0,4,0,0" Opacity="0.4"/>
            <Ellipse Name="HeartbeatDot" Width="8" Height="8" Fill="#5EE7C8" VerticalAlignment="Top" Margin="8,0,0,0" Opacity="0.9" RenderTransformOrigin="0,0.5">
              <Ellipse.RenderTransform>
                <TranslateTransform X="0" Y="0" />
              </Ellipse.RenderTransform>
            </Ellipse>
          </Grid>
        </Grid>
      </Border>

      <Border Grid.Row="1" Grid.Column="2" Height="34" VerticalAlignment="Top" Margin="6,8,6,0">
        <widgets:AlertBannerControl Text="{Binding AlertBannerText}" Severity="{Binding AlertSeverity}"/>
      </Border>

      <!-- Left navigation rail -->
      <Border Grid.Row="1" Grid.Column="0" Margin="0,18,12,0" CornerRadius="12" Background="#0F071017" BorderBrush="#213A50" BorderThickness="1" Padding="8">
        <StackPanel Spacing="8">
          <TextBlock Text="WHITE BRICK" FontSize="12" FontWeight="Bold" Foreground="#C8F6FF" Margin="6,4"/>
          <ListBox Name="NavList" SelectedIndex="0">
            <ListBoxItem>Dashboard</ListBoxItem>
            <ListBoxItem>Network</ListBoxItem>
            <ListBoxItem>Devices</ListBoxItem>
            <ListBoxItem>Power</ListBoxItem>
            <ListBoxItem>Alerts</ListBoxItem>
            <ListBoxItem>Analytics</ListBoxItem>
            <ListBoxItem>Settings</ListBoxItem>
          </ListBox>
        </StackPanel>
      </Border>

      <Border Grid.Row="1" Grid.Column="1" Margin="0,18,12,0" CornerRadius="20" Background="#D00A1020" BorderBrush="#1F6A8D" BorderThickness="1" Padding="14">
        <Grid RowDefinitions="Auto,Auto,*,Auto">
          <TextBlock Text="INFRASTRUCTURE" FontSize="18" FontWeight="Bold" Foreground="#C8F6FF"/>
          <StackPanel Grid.Row="1" Spacing="7" Margin="0,12,0,10">
            <widgets:InfrastructureCardControl Height="44" DeviceName="Internet" Status="ONLINE" Load="0.96"/>
            <widgets:InfrastructureCardControl Height="44" DeviceName="Gateway" Status="ONLINE" Load="0.87"/>
            <widgets:InfrastructureCardControl Height="44" DeviceName="Honeycutt5" Status="ONLINE" Load="0.72"/>
            <widgets:InfrastructureCardControl Height="44" DeviceName="Honeycuttt24" Status="ONLINE" Load="0.61"/>
            <widgets:InfrastructureCardControl Height="44" DeviceName="WB-Core-01" Status="STAGED" Load="0.33"/>
            <widgets:InfrastructureCardControl Height="44" DeviceName="My Book 01" Status="ONLINE" Load="0.82"/>
            <widgets:InfrastructureCardControl Height="44" DeviceName="My Book 02" Status="ONLINE" Load="0.79"/>
          </StackPanel>

          <Border Grid.Row="2" CornerRadius="14" Background="#B0090C18" BorderBrush="#5B4CFF" BorderThickness="1" Padding="8">
            <Grid RowDefinitions="*,*,*">
              <widgets:HistoryGraphControl Values="{Binding HistoryValues}" Label="NETWORK SCORE"/>
              <widgets:HistoryGraphControl Grid.Row="1" Values="{Binding LatencyValues}" Label="LATENCY"/>
              <widgets:HistoryGraphControl Grid.Row="2" Values="{Binding CpuValues}" Label="CPU"/>
            </Grid>
          </Border>

          <Grid Grid.Row="3" ColumnDefinitions="*,*" Margin="0,12,0,0">
            <StackPanel>
              <TextBlock Text="PACKETS / SEC" Foreground="#77C8E8"/>
              <TextBlock Text="{Binding PacketRate}" Foreground="#8EF8FF" FontSize="24" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
              <TextBlock Text="HEALTH" Foreground="#77C8E8"/>
              <TextBlock Text="NOMINAL" Foreground="#6EFFA1" FontSize="24" FontWeight="Bold"/>
            </StackPanel>
          </Grid>
        </Grid>
      </Border>

      <Border Grid.Row="1" Grid.Column="2" Margin="6,18,6,0" CornerRadius="24" Background="#D006101F" BorderBrush="#19B6D2" BorderThickness="1" Padding="18">
        <Grid RowDefinitions="*,130,Auto">
          <widgets:HeroGlobeControl/>

          <Grid Grid.Row="1" ColumnDefinitions="1.45*,*" Margin="0,8,0,0">
            <Border CornerRadius="16" Background="#8A081020" BorderBrush="#245B7D" BorderThickness="1">
              <widgets:PacketStreamControl/>
            </Border>
            <Border Grid.Column="1" Margin="10,0,0,0" CornerRadius="12" Background="#8A081020" BorderBrush="#245B7D" BorderThickness="1">
              <widgets:CameraPreviewWallControl/>
            </Border>
          </Grid>

          <Grid Grid.Row="2" ColumnDefinitions="*,*,*,*" Margin="0,16,0,0">
            <StackPanel>
              <TextBlock Text="NETWORK SCORE" Foreground="#77C8E8"/>
              <TextBlock Text="{Binding NetworkScore}" Foreground="#6EFFA1" FontSize="34" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
              <TextBlock Text="LATENCY" Foreground="#77C8E8"/>
              <TextBlock Text="{Binding Latency}" Foreground="#8EF8FF" FontSize="28" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
              <TextBlock Text="DOWN Mbps" Foreground="#77C8E8"/>
              <TextBlock Text="{Binding Download}" Foreground="#8EF8FF" FontSize="28" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Grid.Column="3">
              <TextBlock Text="UP Mbps" Foreground="#77C8E8"/>
              <TextBlock Text="{Binding Upload}" Foreground="#8EF8FF" FontSize="28" FontWeight="Bold"/>
            </StackPanel>
          </Grid>
        </Grid>
      </Border>

<Border Grid.Row="1" Grid.Column="3" Margin="12,18,0,0" CornerRadius="20" Background="#D00A1020" BorderBrush="#1F6A8D" BorderThickness="1" Padding="12">
  <Grid RowDefinitions="Auto,120,130,122,*,130">
    <TextBlock Text="OPERATIONS STACK" FontSize="18" FontWeight="Bold" Foreground="#C8F6FF"/>

    <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="0,10,0,0">
      <widgets:SystemMicroPanelControl Cpu="{Binding Cpu}" Memory="{Binding Memory}" Packets="{Binding PacketRate}" Mode="{Binding OperatingMode}"/>
      <Grid Grid.Column="1" ColumnDefinitions="*,*">
        <widgets:GaugeRingControl Value="32" Label="CPU"/>
        <widgets:GaugeRingControl Grid.Column="1" Value="48" Label="MEM"/>
      </Grid>
      <!-- Bottom status bar -->
      <Border Grid.Row="2" Grid.ColumnSpan="4" CornerRadius="10" Background="#0B061014" BorderBrush="#123341" BorderThickness="1" Padding="10" Margin="0,12,0,0">
        <Grid ColumnDefinitions="1*,1*,1*,1*,1*">
          <StackPanel>
            <TextBlock Text="SYSTEM HEALTH" Foreground="#BDEEFF" FontSize="12" FontWeight="Bold"/>
          </StackPanel>
          <StackPanel Grid.Column="1">
            <TextBlock Text="TRAFFIC" Foreground="#BDEEFF" FontSize="12" FontWeight="Bold"/>
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Text="LATENCY" Foreground="#BDEEFF" FontSize="12" FontWeight="Bold"/>
          </StackPanel>
          <StackPanel Grid.Column="3">
            <TextBlock Text="ALERTS" Foreground="#BDEEFF" FontSize="12" FontWeight="Bold"/>
          </StackPanel>
          <StackPanel Grid.Column="4">
            <TextBlock Text="UPTIME" Foreground="#BDEEFF" FontSize="12" FontWeight="Bold"/>
          </StackPanel>
        </Grid>
      </Border>

    </Grid>

    <Border Grid.Row="2" Margin="0,10,0,0" CornerRadius="10" Background="#B0090C18" BorderBrush="#245B7D" BorderThickness="1" Padding="0">
      <widgets:WeatherPulseControl Temperature="{Binding WeatherTemperature}" Condition="{Binding WeatherCondition}" Wind="{Binding WeatherWind}"/>
    </Border>

    <Border Grid.Row="3" Margin="0,10,0,0" CornerRadius="10" Background="#B0090C18" BorderBrush="#24D7FF" BorderThickness="1" Padding="6">
      <Grid RowDefinitions="Auto,*">
        <TextBlock Text="RADAR / DEVICE SWEEP" Foreground="#BDEEFF" FontSize="12" FontWeight="Bold"/>
        <widgets:RadarControl Grid.Row="1" Margin="0,4,0,0"/>
      </Grid>
    </Border>

    <Border Grid.Row="4" Margin="0,10,0,0" CornerRadius="10" Background="#D0050811" BorderBrush="#2C3A55" BorderThickness="1" Padding="8">
      <Grid RowDefinitions="Auto,*">
        <TextBlock Text="LIVE CONSOLE" Foreground="#BDEEFF" FontSize="12" FontWeight="Bold"/>
        <ListBox Grid.Row="1" ItemsSource="{Binding ConsoleLines}" Background="Transparent" BorderThickness="0" Foreground="#BDEEFF" FontSize="11"/>
      </Grid>
    </Border>

    <Border Grid.Row="5" Margin="0,10,0,0" CornerRadius="10" Background="#B0090C18" BorderBrush="#5B4CFF" BorderThickness="1" Padding="0">
      <widgets:TimelineStreamControl Events="{Binding TimelineEvents}"/>
    </Border>
  </Grid>
</Border>

    </Grid>

    <Border HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Width="420"
            Height="220"
            Margin="0,96,24,0"
            IsVisible="{Binding DeveloperOverlayVisible}"
            CornerRadius="12"
            Background="#00000000">
      <widgets:DeveloperOverlayControl EngineVersion="{Binding EngineVersion}"
                                       SceneNodes="{Binding SceneNodeCount}"
                                       DisplayZones="{Binding DisplayZoneCount}"
                                       Assets="{Binding RegisteredAssetCount}"/>
    </Border>
  </Grid>
</Window>
