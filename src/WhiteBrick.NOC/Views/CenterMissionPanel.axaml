<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:widgets="clr-namespace:WhiteBrick.NOC.Widgets"
             x:Class="WhiteBrick.NOC.Views.CenterMissionPanel">

  <Border CornerRadius="24"
          Background="#D006101F"
          BorderBrush="#19B6D2"
          BorderThickness="1"
          Padding="18">

    <Grid RowDefinitions="Auto,*,150,Auto"
          RowSpacing="14">

      <Border Grid.Row="0"
              MinHeight="34">
        <widgets:AlertBannerControl Text="{Binding AlertBannerText}"
                                    Severity="{Binding AlertSeverity}"/>
      </Border>

      <Border Grid.Row="1"
              CornerRadius="20"
              Background="#52070D18"
              BorderBrush="#123642"
              BorderThickness="1"
              ClipToBounds="True">
        <widgets:HeroGlobeControl HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Margin="8"/>
      </Border>

      <Grid Grid.Row="2"
            ColumnDefinitions="1.8*,*"
            ColumnSpacing="12">

        <Border CornerRadius="16"
                Background="#8A081020"
                BorderBrush="#245B7D"
                BorderThickness="1"
                Padding="8"
                ClipToBounds="True">
          <widgets:PacketStreamControl/>
        </Border>

        <Border Grid.Column="1"
                CornerRadius="16"
                Background="#8A081020"
                BorderBrush="#245B7D"
                BorderThickness="1"
                Padding="8"
                ClipToBounds="True">
          <widgets:CameraPreviewWallControl/>
        </Border>

      </Grid>

      <Grid Grid.Row="3"
            ColumnDefinitions="*,*,*,*"
            ColumnSpacing="12">

        <Border CornerRadius="14" Background="#7209121F" Padding="12">
          <StackPanel>
            <TextBlock Text="NETWORK SCORE" Foreground="#77C8E8" FontSize="11"/>
            <TextBlock Text="{Binding NetworkScore}" Foreground="#6EFFA1" FontSize="34" FontWeight="Bold"/>
          </StackPanel>
        </Border>

        <Border Grid.Column="1" CornerRadius="14" Background="#7209121F" Padding="12">
          <StackPanel>
            <TextBlock Text="LATENCY" Foreground="#77C8E8" FontSize="11"/>
            <TextBlock Text="{Binding Latency}" Foreground="#8EF8FF" FontSize="28" FontWeight="Bold"/>
          </StackPanel>
        </Border>

        <Border Grid.Column="2" CornerRadius="14" Background="#7209121F" Padding="12">
          <StackPanel>
            <TextBlock Text="DOWN Mbps" Foreground="#77C8E8" FontSize="11"/>
            <TextBlock Text="{Binding Download}" Foreground="#8EF8FF" FontSize="28" FontWeight="Bold"/>
          </StackPanel>
        </Border>

        <Border Grid.Column="3" CornerRadius="14" Background="#7209121F" Padding="12">
          <StackPanel>
            <TextBlock Text="UP Mbps" Foreground="#77C8E8" FontSize="11"/>
            <TextBlock Text="{Binding Upload}" Foreground="#8EF8FF" FontSize="28" FontWeight="Bold"/>
          </StackPanel>
        </Border>

      </Grid>

    </Grid>
  </Border>
</UserControl>
